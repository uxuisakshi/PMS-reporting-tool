# Copy this file to .env.local and fill in your values
# .env.local is gitignored - never commit actual credentials

# Database
DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password

# Migration tool password (required to access database/migrate.php)
MIGRATION_PASSWORD=choose-a-strong-password-here

# SMTP Email
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your_smtp_password

# Vault encryption key (base64 encoded 32-byte key)
# Generate with: php -r "echo base64_encode(random_bytes(32));"
VAULT_ENCRYPTION_KEY=

# Vault key salt for PBKDF2 (base64 encoded random string)
# Generate with: php -r "echo base64_encode(random_bytes(16));"
VAULT_KEY_SALT=

# App key for general encryption
APP_KEY=

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
