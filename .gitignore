# Runtime PHP session files
tmp/sessions/*
!tmp/sessions/.gitkeep

# Local scan artifacts
assets/uploads/automated_findings/

# Local Node dependencies (tooling)
tools/accessibility/node_modules/

# Runtime logs
tmp/logs/*.log
api/*.log

# Local environment variables (never commit)
.env.local
.env
.env.*
!.env.example

# Local database config override (never commit)
config/database.local.php

node_modules/

# User Uploads & dynamic assets
uploads/*
!uploads/.gitkeep
assets/uploads/*
!assets/uploads/.gitkeep
storage/*
!storage/.gitkeep

# Temporary / Runtime Files
tmp/*
!tmp/.gitkeep

# Diagnostic / one-off scripts (should never be committed)
*diag*.php
*test_token*.php
fix_tokens.php

# Office Temp Files
~$*
